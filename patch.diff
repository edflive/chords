+
+    sequenceToPlay = userSequence;
+
+    if (isPlaying) {
+        stopPlayback();
+    } else if (previouslyHighlightedStepIndex >= 0) {
+        const previousLi = sequenceListElement.querySelector(`li[data-index="${previouslyHighlightedStepIndex}"]`);
