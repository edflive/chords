+            previousLi.classList.remove('playing-step');
+        }
+        previouslyHighlightedStepIndex = -1;
+    }
+
+    currentStepInSequence = stepIndex;
+    currentBeatInChord = 0;
+    beatCountSinceStart = userSequence
